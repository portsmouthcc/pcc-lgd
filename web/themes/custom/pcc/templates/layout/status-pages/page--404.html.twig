{% if default_status_content %}
	{% set default_status_content %}
	<div class="four04-content">
		<p>{{ "We couldn't find the page you're looking for. It's possible you entered the address incorrectly or you're looking for a page we've moved or deleted."|t }}</p>

		<div class="four04-search">
			{{ drupal_region('search') }}
		</div>
		<p>
			{{ 'Please try using the search bar above or clicking the <a href="/">Portsmouth City Council logo</a> to navigate back to the home page.'|t|raw }}
		</p>
	</div>
	{% endset %}
{% endif %}

