{# Use this in service navigations for all the various content types. #}

{% set content_type = node.bundle %}

{% set classes = ['service-teaser', 'teaser', 'teaser--' ~ (content_type|clean_class), 'node', 'node--type-' ~ (node.bundle|clean_class), node.isPromoted() ? 'node--promoted', node.isSticky() ? 'node--sticky', not node.isPublished() ? 'node--unpublished', view_mode ? 'node--view-mode-' ~ (view_mode|clean_class), 'pb-4'] %}

<article {{ attributes.addClass(classes).removeAttribute('role') }}>
  <a href="{{ url }}" rel="bookmark">
    <div>
      <h3 class="has-text-weight-bold has-text-link is-underlined">{{ label }}</h3>
      <p class="has-text-text">{{ node.body.summary }}</p>
    </div>
  </a>
</article>
