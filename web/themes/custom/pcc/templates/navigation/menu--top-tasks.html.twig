{# This simply uses a grid but flows horizontally. #}
{% if items %}
  <div class="fixed-grid has-1-cols-mobile has-2-cols-tablet has-3-cols-desktop">
    <div class="grid is-gap-0">
      {% for item in items %}
        <div class="cell">
          {% include '@pcc/components/top-task.html.twig' with { link: item } %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}
