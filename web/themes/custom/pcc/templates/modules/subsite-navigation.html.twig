{{ attach_library('pcc/subsite-navigation') }}

{% import _self as subsite_navigation %}

{{ subsite_navigation.menu_links(items, attributes, 0) }}

{% macro menu_links(items, attributes, menu_level) %}
	{% import _self as subsite_navigation %}

	{% if items %}
		<ul class="menu menu--level-{{ menu_level }}">
			{% for item in items %}
				{% set classes = [
          'menu-item',
          item.is_expanded ? 'menu-item--expanded',
          item.in_active_trail ? 'menu-item--active-trail',
          item.below ? 'menu-item--has-children'
        ] %}

				<li{{item.attributes.addClass(classes)}}>

					<div
						class="menu-item__inner">

						{# Link #}
						{% if item.url is not empty %}
							<a href="{{ item.url }}" class="menu-link">
								{{ item.title }}
							</a>
						{% else %}
							<span class="menu-link">{{ item.title }}</span>
						{% endif %}

						{# Toggle button for children #}
						{% if item.below %}
							<button class="menu-toggle" aria-expanded="{{ item.in_active_trail ? 'true' : 'false' }}">
								<span class="visually-hidden">Toggle submenu</span>
							</button>
						{% endif %}

					</div>

					{# Children #}
					{% if item.below %}
						<div class="menu-children {{ item.in_active_trail ? 'is-open' : '' }}">
							{{ subsite_navigation.menu_links(item.below, attributes, menu_level + 1) }}
						</div>
					{% endif %}

				</li>
			{% endfor %}
		</ul>
	{% endif %}
{% endmacro %}
