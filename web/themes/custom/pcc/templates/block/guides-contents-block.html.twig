{#
/**
* @file
* Default theme implementation for the guides_contents_block block.
*/
#}

{% if links %}

  {% if format == 'ordered' %}
    {% set list_type = 'ol' %}
    {% else %}
      {% set list_type = 'ul' %}
  {% endif %}
  <h2 class="visually-hidden">{{ 'Guide Navigation'|t }}</h2>
  <a class="visually-hidden focusable" href="#lgd-guides__title">{{ 'Skip Guide Navigation'|t }}</a>
  <nav class="menu" aria-label="{{ 'Guide'|t }}">
    <{{ list_type }} class="menu-list">
      {% for link in links %}
        {% if link.url.options.attributes.class == 'active' %}
          <li aria-current="page"><a class="is-active" href="{{ link.url }}">{{ link.text }}</a></li>
          {% else %}
            <li class="">{{ link }}</li>
        {% endif %}
      {% endfor %}
    </{{ list_type }}>
  </nav>

{% endif %}
