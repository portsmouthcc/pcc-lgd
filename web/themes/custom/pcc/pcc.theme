<?php

/**
 * @file
 * Theme function for the Portsmouth City Council theme.
 */

/**
 * Implements hook_theme().
 */
function pcc_theme($existing, $type, $theme, $path): array {
  // Register custom templates.
  return [
    'paragraph__banner_home_page' => [
      'template' => 'paragraphs/paragraph--banner-home-page',
      'base hook' => 'paragraph',
    ],
  ];
}
